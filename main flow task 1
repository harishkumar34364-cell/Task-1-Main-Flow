\"Quantity\"] * data[\"UnitPrice\"]\n","\n","# -------------------------------\n","# Date Conversion & Time Features\n","# -------------------------------\n","\n","data[\"InvoiceDate\"] = pd.to_datetime(data[\"InvoiceDate\"])\n","\n","data[\"Month\"] = data[\"InvoiceDate\"].dt.month\n","data[\"Day\"] = data[\"InvoiceDate\"].dt.day\n","data[\"Hour\"] = data[\"InvoiceDate\"].dt.hour\n","data[\"DayOfWeek\"] = data[\"InvoiceDate\"].dt.day_name()\n","\n","# -------------------------------\n","# Data Quality Report\n","# -------------------------------\n","\n","print(\"\\n------ DATA QUALITY REPORT ------\")\n","\n","print(\"Cancelled Orders Removed :\", cancelled_orders)\n","print(\"Invalid Quantity/Price Rows Removed :\", invalid_rows)\n","print(\"Duplicate Rows Removed :\", duplicate_rows)\n","\n","print(\"\\nMissing Value Percentage:\")\n","print(missing_percent)\n","\n","print(\"\\nFinal Dataset Shape :\", data.shape)\n","\n","# -------------------------------\n","# Export Clean Data\n","# -------------------------------\n","\n","data.to_csv(\"OnlineRetail_Cleaned.csv\", index=False)\n","\n","print(\"\\nCleaned dataset saved successfully.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"0z6ekU4LiXmk","executionInfo":{"status":"ok","timestamp":1780374478938,"user_tz":-330,"elapsed":63466,"user":{"displayName":"Harish kumar","userId":"00361762128713396236"}},"outputId":"ccd37f6a-6402-494e-8a2f-41542ed57ece"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["Original Dataset Shape : (541909, 8)\n","\n","Missing Values:\n","InvoiceNo           0\n","StockCode           0\n","Description      1454\n","Quantity            0\n","InvoiceDate         0\n","UnitPrice           0\n","CustomerID     135080\n","Country             0\n","dtype: int64\n","\n","Shape after handling missing values:\n","(406829, 8)\n","\n","------ DATA QUALITY REPORT ------\n","Cancelled Orders Removed : 8905\n","Invalid Quantity/Price Rows Removed : 40\n","Duplicate Rows Removed : 5192\n","\n","Missing Value Percentage:\n","InvoiceNo       0.000000\n","StockCode       0.000000\n","Description     0.268311\n","Quantity        0.000000\n","InvoiceDate     0.000000\n","UnitPrice       0.000000\n","CustomerID     24.926694\n","Country         0.000000\n","dtype: float64\n","\n","Final Dataset Shape : (392692, 13)\n","\n","Cleaned dataset saved successfully.\n"]}]},{"cell_type":"markdown","metadata":{"id":"6edd2592"},"source":["## Task 2 - Customer Segmentation using RFM Analysis\n","\n","RFM (Recency, Frequency, Monetary) analysis is a marketing technique used to quantitatively rank and group customer behavior based on the recency of their last purchase, how often they purchase, and how much they spend. This segmentation can help identify high-value customers, loyal customers, and those at risk of churning."]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":206},"id":"8e21c38b","executionInfo":{"status":"ok","timestamp":1780374556073,"user_tz":-330,"elapsed":522,"user":{"displayName":"Harish kumar","userId":"00361762128713396236"}},"outputId":"792d6084-21ef-4d5d-e94e-3895b7552365"},"source":["# Calculate Recency, Frequency, and Monetary values\n","\n","# Recency: How recently did the customer purchase?\n","# To calculate recency, we need a 'snapshot date' which is typically the day after the last transaction in the dataset.\n","snapshot_date = data['InvoiceDate'].max() + pd.Timedelta(days=1)\n","\n","rfm = data.groupby('CustomerID').agg(\n","    Recency=('InvoiceDate', lambda date: (snapshot_date - date.max()).days),\n","    Frequency=('InvoiceNo', 'nunique'),\n","    Monetary=('TotalPrice', 'sum')\n",").reset_index()\n","\n","# Display the first 5 rows of the RFM dataframe\n","display(rfm.head())"],"execution_count":4,"outputs":[{"output_type":"display_data","data":{"text/plain":["   CustomerID  Recency  Frequency  Monetary\n","0     12346.0      326          1  77183.60\n","